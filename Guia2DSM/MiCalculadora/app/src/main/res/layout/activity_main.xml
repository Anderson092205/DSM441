<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tvResultado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0"
        android:textSize="48sp"
        android:textColor="#000000"
        android:gravity="end"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/etNumero"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ingrese un número"
        android:textColorHint="#888888"
        android:textColor="#000000"
        android:inputType="numberDecimal|numberSigned"
        android:padding="12dp"
        android:textSize="24sp"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="4">
        <Button android:id="@+id/btnSuma" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="+" android:textSize="24sp" android:layout_margin="4dp"/>
        <Button android:id="@+id/btnResta" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="-" android:textSize="24sp" android:layout_margin="4dp"/>
        <Button android:id="@+id/btnMulti" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="×" android:textSize="24sp" android:layout_margin="4dp"/>
        <Button android:id="@+id/btnDiv" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="÷" android:textSize="24sp" android:layout_margin="4dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        android:layout_marginTop="8dp">
        <Button android:id="@+id/btnPorcentaje" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="%" android:textSize="20sp" android:layout_margin="4dp"/>
        <Button android:id="@+id/btnCuadrado" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="x²" android:textSize="20sp" android:layout_margin="4dp"/>
        <Button android:id="@+id/btnRaiz" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="√" android:textSize="20sp" android:layout_margin="4dp"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnLimpiarTodo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Limpiar Todo"
        android:textColor="#FFFFFF"
        android:backgroundTint="#D32F2F"
        android:layout_margin="4dp"
        android:layout_marginTop="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Historial (Últimas 5):"
        android:textColor="#555555"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        android:layout_marginStart="4dp"/>

    <TextView
        android:id="@+id/tvHistorial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#333333"
        android:textSize="18sp"
        android:layout_marginTop="8dp"
        android:layout_marginStart="4dp"/>

</LinearLayout>